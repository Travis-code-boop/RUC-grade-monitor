RUC_TOKEN=replace_with_token_header_value
PUSHPLUS_TOKEN=replace_with_pushplus_token
GRADE_HASH_SALT=replace_with_random_secret

# Optional. Keep empty unless the school gateway requires browser cookies too.
RUC_COOKIE=

# Optional filters. Leave empty to query all semesters visible to the account.
RUC_SEMESTERS=
RUC_PAGE_SIZE=100
RUC_PLAN_TYPE=1
RUC_BROWSER_USER_AGENT=
STATE_FILE=seen_grades.json
